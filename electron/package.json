{
  "name": "sketchdb-desktop",
  "version": "1.0.2",
  "private": true,
  "author": "SketchDB",
  "description": "SketchDB Windows desktop app",
  "main": "src/main.js",
  "scripts": {
    "generate:icon": "node ./scripts/generate-icon.js",
    "build:client": "npm --prefix ../client run build:desktop",
    "start": "npm run generate:icon && npm run build:client && electron .",
    "dist": "npm run generate:icon && npm run build:client && electron-builder --win nsis portable"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.sketchdb.desktop",
    "productName": "SketchDB",
    "forceCodeSigning": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../client/dist",
        "to": "client-dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SketchDB"
    }
  }
}
